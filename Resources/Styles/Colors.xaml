<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Dark Mode Primary Colors -->
    <Color x:Key="Primary">#512BD4</Color>
    <Color x:Key="Secondary">#9880E5</Color>
    <Color x:Key="Tertiary">#B4A7FF</Color>

    <!-- Neutral Colors -->
    <Color x:Key="Black">#000000</Color>
    <Color x:Key="White">#FFFFFF</Color>
    <Color x:Key="Surface">#1F1F1F</Color>
    <Color x:Key="SurfaceVariant">#2A2A2A</Color>
    <Color x:Key="OnSurface">#FFFFFF</Color>
    <Color x:Key="OnSurfaceVariant">#B3B3B3</Color>

    <!-- Semantic Colors -->
    <Color x:Key="Success">#4CAF50</Color>
    <Color x:Key="Warning">#FFC107</Color>
    <Color x:Key="Error">#F44336</Color>
    <Color x:Key="Info">#2196F3</Color>

    <!-- Grayscale (simplified) -->
    <Color x:Key="Gray50">#F5F5F5</Color>
    <Color x:Key="Gray100">#E0E0E0</Color>
    <Color x:Key="Gray200">#BDBDBD</Color>
    <Color x:Key="Gray300">#9E9E9E</Color>
    <Color x:Key="Gray400">#757575</Color>
    <Color x:Key="Gray500">#616161</Color>
    <Color x:Key="Gray600">#424242</Color>
    <Color x:Key="Gray700">#303030</Color>
    <Color x:Key="Gray800">#212121</Color>
    <Color x:Key="Gray900">#121212</Color>

    <!-- Brushes (Material 3 style) -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Primary}"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource Secondary}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource Surface}"/>
    <SolidColorBrush x:Key="OnSurfaceBrush" Color="{StaticResource OnSurface}"/>

</ResourceDictionary>