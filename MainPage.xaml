<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Telegram.Bot.MainPage"
             Title="Mensagens do Grupo">

    <Grid Padding="16,0">
        <RefreshView Command="{Binding RefreshCommand}"
                     IsRefreshing="{Binding IsRefreshing}">

            <CollectionView ItemsSource="{Binding Messages}" 
                            SelectionMode="None"
                            EmptyView="Nenhuma mensagem ainda">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="8" Margin="0,8">
                            <Grid RowDefinitions="*,*" ColumnDefinitions="*, Auto" ColumnSpacing="8" RowSpacing="4">
                                <Label Text="{Binding SenderName, StringFormat='@{0}'}" 
                                       FontAttributes="Bold" 
                                       FontSize="13" 
                                       TextColor="#FFF"
                                       LineBreakMode="TailTruncation"
                                       Grid.Column="0"/>

                                <Label Text="{Binding Date, StringFormat='{0:dd/mm/yyyy - HH:mm}'}" 
                                       FontSize="11" 
                                       TextColor="#999999"
                                       Grid.Column="1" 
                                       HorizontalTextAlignment="End"/>

                                <Label Text="{Binding Text}" 
                                   FontSize="13" 
                                   Grid.Row="1"
                                   Grid.ColumnSpan="2" 
                                   LineBreakMode="WordWrap"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>
    </Grid>

</ContentPage>
