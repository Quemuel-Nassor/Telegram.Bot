<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Telegram.Bot.MainPage"
             Title="Mensagens do Grupo">

    <Grid Style="{StaticResource ContentGridStyle}">
        <RefreshView Command="{Binding RefreshCommand}"
                     IsRefreshing="{Binding IsRefreshing}">

            <CollectionView ItemsSource="{Binding Messages}" 
                            SelectionMode="Single"
                            SelectionChangedCommand="{Binding ShowContextMenuCommand}"
                            SelectionChangedCommandParameter="{Binding SelectedItem, Source={RelativeSource Self}}"
                            EmptyView="Nenhuma mensagem ainda">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource MessageCardStyle}">
                            <Grid RowDefinitions="*,*" ColumnDefinitions="*, Auto" ColumnSpacing="8" RowSpacing="4">
                                <Label Text="{Binding SenderName, StringFormat='@{0}'}" 
                                       Style="{StaticResource HeaderLabelStyle}"
                                       LineBreakMode="TailTruncation"
                                       Grid.Column="0"/>

                                <Label Text="{Binding Date, StringFormat='{0:dd/mm/yyyy - HH:mm}'}" 
                                       Style="{StaticResource SecondaryLabelStyle}"
                                       Grid.Column="1"
                                       HorizontalTextAlignment="End"/>

                                <Label Text="{Binding Text}" 
                                       TextColor="{StaticResource OnSurface}"
                                       FontSize="13"
                                       Grid.Row="1"
                                       Grid.ColumnSpan="2"
                                       LineBreakMode="WordWrap"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>
    </Grid>

</ContentPage>
