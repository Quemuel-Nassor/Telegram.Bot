<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Telegram.Bot.ConfigPage"
             Title="Configurações">

    <VerticalStackLayout Padding="20" Spacing="15">
        <Label Text="Token da API do Telegram" 
               FontAttributes="Bold" 
               FontSize="16"
               Margin="0, 10, 0, 0"/>
        
        <Entry Text="{Binding Token, Mode=TwoWay}" 
               Placeholder="Insira seu token aqui"
               IsPassword="True"
               FontSize="14"
               ReturnType="Done"
               Margin="0, 0, 0, 10"/>
        
        <Label Text="Obtém o token em: @BotFather no Telegram" 
               FontSize="12" 
               TextColor="#666666"
               Margin="0, 5, 0, 0"/>
        
        <Button Text="Salvar Token" 
                Command="{Binding SaveCommand}"
                BackgroundColor="#512BD4"
                TextColor="White"
                Margin="0, 20, 0, 0"
                CornerRadius="4"/>
    </VerticalStackLayout>

</ContentPage>
