<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Telegram.Bot.ConfigPage"
             Title="Configurações">

    <Grid RowDefinitions="auto,auto,auto,auto" 
          RowSpacing="8"
          Padding="16,0">
        <Label Text="Token da API do Telegram" 
               FontAttributes="Bold" 
               FontSize="16"/>

        <Entry Grid.Row="1" Text="{Binding Token, Mode=TwoWay}" 
               Placeholder="Insira seu token aqui"
               IsPassword="True"
               FontSize="14"
               ReturnType="Done"/>

        <Label Grid.Row="2" Text="Obtém o token em: @BotFather no Telegram" 
               FontSize="12" 
               TextColor="#666666"/>

        <Button Grid.Row="3" Text="Salvar Token" 
                Command="{Binding SaveCommand}"
                BackgroundColor="#512BD4"
                TextColor="White"
                CornerRadius="4"/>
    </Grid>

</ContentPage>
