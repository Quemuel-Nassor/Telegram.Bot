<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Telegram.Bot.ConfigPage"
             Title="Configurações">

    <Grid Style="{StaticResource ConfigFormGridStyle}" RowDefinitions="auto,auto,auto,auto">
        <Label Text="Token da API do Telegram" 
               Style="{StaticResource TitleLabelStyle}"/>

        <Entry Grid.Row="1" 
               Text="{Binding Token, Mode=TwoWay}" 
               Placeholder="Insira seu token aqui"
               IsPassword="True"
               ReturnType="Done"
               Margin="0,8"/>

        <Label Grid.Row="2" 
               Text="Obtém o token em: @BotFather no Telegram" 
               Style="{StaticResource HelperTextLabelStyle}"/>

        <Button Grid.Row="3" 
                Text="Salvar Token" 
                Command="{Binding SaveCommand}"
                Margin="0,16,0,0"/>
    </Grid>

</ContentPage>
