<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Telegram.Bot.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:Telegram.Bot"
    Title="Telegram.Bot"
    TabBarBackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1F1F1F}"
    TabBarForegroundColor="{AppThemeBinding Light=#512BD4, Dark=#B4A7FF}"
    TabBarUnselectedColor="{AppThemeBinding Light=#999999, Dark=#666666}"
    TabBarIsVisible="True">

    <TabBar>
        <ShellContent
            Title="Mensagens"
            ContentTemplate="{DataTemplate local:MainPage}"
            Route="messages" />

        <ShellContent
            Title="Configuração"
            ContentTemplate="{DataTemplate local:ConfigPage}"
            Route="settings" />
    </TabBar>

</Shell>
