<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Telegram.Bot.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:Telegram.Bot"
    Title="Telegram.Bot"
    TabBarIsVisible="True">

    <TabBar>
        <ShellContent
            Title="Configuração"
            Icon="{FontImageSource Glyph='⚙️'}"
            ContentTemplate="{DataTemplate local:ConfigPage}"/>

        <ShellContent
            Title="Mensagens"
            Icon="{FontImageSource Glyph='💬'}"
            ContentTemplate="{DataTemplate local:MainPage}"/>
    </TabBar>

</Shell>
