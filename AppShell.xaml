<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Telegram.Bot.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:Telegram.Bot"
    Title="Telegram.Bot"
    TabBarBackgroundColor="{AppThemeBinding Light=#F0F0F0, Dark=#1F1F1F}"
    TabBarForegroundColor="{AppThemeBinding Light=#000, Dark=#FFF}"
    TabBarUnselectedColor="{AppThemeBinding Light=#999, Dark=#666}">

    <TabBar>
        <ShellContent
            Title="Mensagens"
            Icon="message_icon.png"
            ContentTemplate="{DataTemplate local:MainPage}"
            Route="messages" />

        <ShellContent
            Title="Configuração"
            Icon="settings_icon.png"
            ContentTemplate="{DataTemplate local:ConfigPage}"
            Route="settings" />
    </TabBar>

</Shell>
